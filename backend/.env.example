# App
PORT=3001
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=8h

# Postgres (Prisma)
DATABASE_URL="postgresql://webmais:webmais@localhost:5432/webmais_contratos?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
CACHE_TTL_SECONDS=60

# Kafka
KAFKA_BROKERS="localhost:29092"
KAFKA_CLIENT_ID="webmais-contratos"
KAFKA_TOPIC_CONTRACTS_EXPIRED="contracts.expired"
KAFKA_CONSUMER_GROUP="contracts-expiration-worker"
EXPIRATION_SCHEDULER_INTERVAL_MS=15000
