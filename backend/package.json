{
  "name": "webmais-contratos-backend",
  "version": "0.1.0",
  "description": "API de Gestão de Contratos - desafio técnico WebMais",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:worker": "nest start --watch --entryFile worker.main",
    "start:prod": "node dist/main.js",
    "start:worker:prod": "node dist/worker.main.js",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed.ts"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "dependencies": {
    "@confluentinc/kafka-javascript": "^1.10.0",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.1.28",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.6.1",
    "nestjs-zod": "^5.4.0",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.1",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
